# `docker compose` 用のサンプル環境変数です。
# 必要ならこのファイルを参考にルートへ `.env` を作成して値を上書きしてください。

# PostgreSQL コンテナ作成時の初期ユーザー
POSTGRES_USER=postgres

# PostgreSQL コンテナ作成時の初期パスワード
POSTGRES_PASSWORD=postgres

# 開発用データベース名
POSTGRES_DB=life_simulator_development

# ホスト側で公開する PostgreSQL のポート
POSTGRES_PORT=5432

# ホスト側で公開する Rails API のポート
BACK_PORT=3000

# ホスト側で公開する Vite 開発サーバーのポート
FRONT_PORT=5173
